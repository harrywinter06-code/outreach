# ── LLM Providers (one account each — multi-provider ToS-safe) ──────────────
# NVIDIA NIM: https://build.nvidia.com  (40 RPM per account)
# Add up to 5 keys. Each is treated as an independent rate-limit bucket.
# If a key is banned, the pool drops it; others continue unaffected.
NIM_API_KEY_1=nvapi-xxxxxxxxxxxxxxxxxxxx
# NIM_API_KEY_2=nvapi-xxxxxxxxxxxxxxxxxxxx
# NIM_API_KEY_3=nvapi-xxxxxxxxxxxxxxxxxxxx
# NIM_API_KEY_4=nvapi-xxxxxxxxxxxxxxxxxxxx
# NIM_API_KEY_5=nvapi-xxxxxxxxxxxxxxxxxxxx
# NIM_API_KEY_6=nvapi-xxxxxxxxxxxxxxxxxxxx

# Groq: https://console.groq.com  (one account, 30 RPM per model)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Google Gemini: https://aistudio.google.com  (one account, 15 RPM Flash)
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxx

# Cerebras: https://cloud.cerebras.ai  (one account, 30 RPM)
CEREBRAS_API_KEY=csk-xxxxxxxxxxxxxxxxxxxx

# ── Revenue infrastructure (REQUIRED before first run) ───────────────────────
# Create account at gumroad.com, then: Settings → Advanced → API
GUMROAD_API_KEY=xxxxxxxxxxxxxxxxxxxx

# Stripe is accepted but NOT YET WIRED — setting it triggers a startup warning.
# Revenue capture currently runs through Gumroad only.
# STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx

# ── Infrastructure ───────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=xxxxxxxxxxxxxxxxxxxx
REDIS_PASSWORD=xxxxxxxxxxxxxxxxxxxx
DASHBOARD_API_KEY=xxxxxxxxxxxxxxxxxxxx

REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://clawbot:clawbot@localhost:5432/clawbot

MAX_DAILY_SPEND_USD=5.00

# Kill switch path (host bind-mount in docker-compose). Touching this file halts the agents.
KILL_FILE_PATH=/var/run/clawbot/clawbot.KILL

# ── Operator escalation channels (optional, opt-in) ──────────────────────────
# Telegram bot (recommended — two-way, authenticated):
#   1. Message @BotFather → /newbot → save the token
#   2. Message your bot once, then ask @userinfobot for your numeric chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ntfy.sh push (alternative — one-way, no auth; pick a hard-to-guess topic):
NTFY_TOPIC=
# NTFY_BASE_URL=https://ntfy.sh  # override if you self-host ntfy
